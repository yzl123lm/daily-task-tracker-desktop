# 鲸落AI — 环境变量示例（复制为 .env 仅用于本地开发参考）
# 注意：桌面客户端的 API Key 由应用内设置，并通过 Electron safeStorage 加密后
# 写入用户数据目录，不应把真实密钥提交到 Git 或写进本文件。

# —— 可选：开发/打包 ——
# 跳过 ship 流程中的静默安装（仅调试 release 脚本时使用）
# SKIP_INSTALL=1

# 安装完成后不自动启动应用
# SKIP_LAUNCH_AFTER_INSTALL=1

# electron-builder 证书自动发现（CI/本机无签名证书时可设为 false）
# CSC_IDENTITY_AUTO_DISCOVERY=false

# —— 可选：Ollama 本地模型（应用内也可配置）——
# OLLAMA_HOST=http://127.0.0.1:11434

# —— 请勿在此填写真实值 ——
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# MINIMAX_API_KEY=
