{
  "name": "daily-task-tracker-desktop",
  "version": "1.24.59",
  "description": "鲸落AI 桌面客户端",
  "main": "main.js",
  "author": "local-user",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "prebuild": "python scripts/generate-app-icon.py",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:mac:dmg": "electron-builder --mac dmg",
    "build:mac:zip": "electron-builder --mac zip",
    "build:all": "electron-builder --win --mac",
    "build:nsis": "electron-builder --win nsis",
    "build:portable": "electron-builder --win portable",
    "install:client": "npm run ship:latest-client",
    "ship:latest-client": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ship-latest-client-win.ps1",
    "push:github": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/push-to-github.ps1",
    "release:latest-client": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release-client-to-latest.ps1",
    "start:installed": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-installed-win.ps1",
    "start:client": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-installed-win.ps1",
    "impeccable:sync-skills": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/impeccable-cursor-skills-sync.ps1",
    "impeccable:register-monthly-task": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-impeccable-monthly-task.ps1",
    "taste-skill:update-sync": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/taste-skill-update-sync.ps1",
    "taste-skill:register-weekly-task": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-taste-skill-weekly-task.ps1",
    "kb:eval": "node scripts/kb-eval.js --golden config/kb-eval-golden.json",
    "kb:security-eval": "node scripts/kb-security-eval.js",
    "kb:delete-consistency-test": "node scripts/kb-delete-consistency-test.js",
    "kb:archive-test": "node scripts/kb-archive-test.js",
    "kb:diagnose-doc": "node scripts/kb-diagnose-doc.js",
    "fix:ollama-models-path": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fix-ollama-models-path-win.ps1",
    "restart:ollama-english-models": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart-ollama-english-models.ps1",
    "pull:kb-rerank-model": "ollama pull dengcao/bge-reranker-v2-m3",
    "preload:kb-rerank-model": "node scripts/kb-preload-rerank-model.js",
    "icons:generate": "python scripts/generate-app-icon.py",
    "wb:eval": "node scripts/wb-eval-harness.js",
    "wb:eval:test": "node scripts/wb-eval-harness-test.js",
    "wb:eval:agent": "node scripts/wb-eval-agent-harness.js --repeats 1",
    "wb:eval:agent:test": "node scripts/wb-eval-agent-harness-test.js",
    "wb:a3-test": "node scripts/wb-a3-trusted-autoapply-test.js",
    "wb:replay": "node scripts/wb-agent-replay.js",
    "wb:replay:test": "node scripts/wb-agent-replay-test.js",
    "wb:ux007-test": "node scripts/wb-ux007-req011-ux006-test.js",
    "wb:req011-test": "node scripts/wb-ux007-req011-ux006-test.js",
    "wb:ux006-test": "node scripts/wb-ux007-req011-ux006-test.js",
    "wb:sandbox-test": "node scripts/wb-sandbox-security-test.js",
    "wb:bl009-test": "node scripts/wb-bl009-012-test.js",
    "wb:bl013-test": "node scripts/wb-bl013-014-test.js",
    "wb:bl015-test": "node scripts/wb-bl015-018-test.js",
    "wb:bl019-test": "node scripts/wb-bl019-020-test.js",
    "wb:bl021-test": "node scripts/wb-bl021-022-test.js",
    "wb:sec013-redteam": "node scripts/wb-sec013-redteam-test.js",
    "wb:security-gate": "npm run wb:sec013-redteam && npm run kb:security-eval"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "apache-arrow": "^18.1.0",
    "diff": "^9.0.0",
    "docx": "^9.5.1",
    "jszip": "^3.10.1",
    "lunar-javascript": "^1.7.7",
    "mammoth": "^1.9.0",
    "opencc-js": "^1.0.5",
    "pdf-parse": "^1.1.1",
    "pdf-to-png-converter": "^3.14.0",
    "pdfkit": "^0.17.2",
    "sql.js": "^1.14.1",
    "tesseract.js": "^7.0.0",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.2"
  },
  "build": {
    "appId": "com.local.dailytasktracker",
    "productName": "鲸落AI",
    "icon": "build/icon.ico",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "main/**/*.js",
      "preload.js",
      "splash.html",
      "splash.css",
      "splash.js",
      "splash-preload.js",
      "index.html",
      "styles.css",
      "ui-nebula-theme.css",
      "ui-float-desktop.css",
      "ui-recorder-window.css",
      "kb-dashboard.css",
      "kb-config-layout.css",
      "workbench-dev.css",
      "utils/dom.js",
      "utils/settingsStore.js",
      "utils/ipcValidate.js",
      "utils/sanitizeHtml.js",
      "utils/kbRetrieval.js",
      "utils/kbFtsIndex.js",
      "utils/kbSqliteStore.js",
      "utils/kbAutoLearn.js",
      "utils/kbConfigLayout.js",
      "utils/kbModelHealth.js",
      "utils/kbRerank.js",
      "utils/ollamaEmbedError.js",
      "app/**/*.js",
      "app/**/*.css",
      "ai/aiDocVisual.js",
      "main/apiNormalize.js",
      "main/aiSessionStore.js",
      "main/miniMaxHints.js",
      "main/kbWatchDir.js",
      "app.js",
      "taskEnhancements.js",
      "taskAnalytics.js",
      "localModels.js",
      "ai.js",
      "providerBrandIcons.js",
      "docPreviewController.js",
      "environmentSetup.js",
      "taskAttachmentsUI.js",
      "capability.js",
      "media.js",
      "skills.js",
      "runtimePrerequisites.js",
      "searchPipeline.js",
      "lunarCalendarMain.js",
      "cnlunarMain.js",
      "scripts/cnlunar_query.py",
      "scripts/kb-preload-rerank-model.js",
      "scripts/kb-excel-to-text.ps1",
      "utils/kbIngestPasswords.js",
      "utils/kbDocPasswordVault.js",
      "utils/kbFeatureGates.js",
      "utils/kbDeleteRepair.js",
      "utils/kbArchive.js",
      "utils/kbPromptSafety.js",
      "utils/wbModelOutputSanitizer.js",
      "config/kb-security-golden.json",
      "build/icon.ico",
      "build/icon.png",
      "build/whale-mascot.png",
      "prerequisites-manifest.json",
      "environmentManifest.json",
      "recorder.js",
      "knowledgeBaseMain.js",
      "knowledgeBase.js",
      "wordFormalExport.js",
      "pdfFormalExport.js",
      "README.md"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "verifyUpdateCodeSignature": false
    },
    "extraFiles": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "asarUnpack": [
      "scripts/kb-excel-to-text.ps1",
      "scripts/cnlunar_query.py"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "鲸落AI",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "perMachine": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "identity": null,
      "hardenedRuntime": false
    },
    "dmg": {
      "title": "${productName} ${version}",
      "icon": "build/icon.icns"
    }
  }
}
